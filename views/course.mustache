{{> head}}
{{> header}}

<article>
  <h1>{{course.title}}</h1>
  <p class="muted">
    Level: {{course.level}} &bull; Type: {{course.type}}
    {{#course.allowDropIn}}&bull; Drop-in available{{/course.allowDropIn}}
  </p>
  <p>{{course.description}}</p>
  <p class="muted">Dates: {{course.startDate}} &ndash; {{course.endDate}}</p>
  <p class="muted">Location: {{course.location}}</p>
  <p class="muted">Price: {{course.price}}</p>

  <section>
    <h2>Book the full course</h2>
    {{#user}}
    <form action="/courses/{{course.id}}/book" method="post">
      <input type="hidden" name="userId" value="{{user._id}}">
      <button class="btn primary" type="submit">Book full course</button>
    </form>
    {{/user}}
    {{^user}}
    <p><a href="/auth/login" class="btn">Sign in to book</a></p>
    {{/user}}
  </section>

  <section>
    <h2>Sessions</h2>
    <table class="table">
      <thead>
        <tr>
          <th>Start</th>
          <th>End</th>
          <th>Capacity</th>
          <th>Booked</th>
          <th>Remaining</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#sessions}}
        <tr>
          <td>{{start}}</td>
          <td>{{end}}</td>
          <td>{{capacity}}</td>
          <td>{{booked}}</td>
          <td>{{remaining}}</td>
          <td>
            {{#allowDropIn}}
              {{#user}}
              <form method="post" action="/sessions/{{id}}/book">
                <input type="hidden" name="userId" value="{{id}}">
                <button class="btn primary" type="submit">Book this session</button>
              </form>
              {{/user}}
              {{^user}}
                <a href="/auth/login" class="btn">Sign in to book</a>
              {{/user}}
            {{/allowDropIn}}
            {{^allowDropIn}}
              <span class="muted">Drop-ins disabled</span>
            {{/allowDropIn}}
          </td>
        </tr>
        {{/sessions}}
      </tbody>
    </table>
  </section>
</article>

{{> footer}}